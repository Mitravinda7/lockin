{
  "manifest_version": 3,
  "name": "LockIn",
  "version": "1.0",
  "description": "Stay focused. Study only.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "scripting",
    "activeTab",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LockIn"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "stats.html", "stats.js" , "whitelist.html", "whitelist.js", "schedule.js"],
      "matches": ["<all_urls>"]
    }
  ]
}